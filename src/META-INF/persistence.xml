<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="proyectos_fp_2025" transaction-type="RESOURCE_LOCAL">

        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <class>modelo.entities.Empleado</class>
        <class>modelo.entities.Departamento</class>
        <class>modelo.entities.Perfil</class>
        <class>modelo.entities.Cliente</class>
        <class>modelo.entities.Proyecto</class>
        <class>modelo.entities.ProyectoConEmpleados</class>

        <properties>

            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>

            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/proyectos_fp_2025"/>

            <property name="jakarta.persistence.jdbc.user"
                      value="root"/>

            <property name="jakarta.persistence.jdbc.password"
                      value=""/>

            <property name="eclipselink.logging.level"
                      value="FINE"/>

            <property name="eclipselink.ddl-generation"
                      value="create-or-extend-tables"/>

        </properties>

    </persistence-unit>

</persistence>