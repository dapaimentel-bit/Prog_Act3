<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="src"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="lib" path="lib/asm.jar"/>
	<classpathentry kind="lib" path="lib/asm-commons.jar"/>
	<classpathentry kind="lib" path="lib/asm-tree.jar"/>
	<classpathentry kind="lib" path="lib/asm-util.jar"/>
	<classpathentry kind="lib" path="lib/eclipselink.jar"/>
	<classpathentry kind="lib" path="lib/jakarta.persistence-api.jar"/>
	<classpathentry kind="lib" path="lib/mysql-connector-j-9.6.0.jar"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
